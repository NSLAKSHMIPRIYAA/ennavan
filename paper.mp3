span> </span><span class="ͼ12">id</span><span class="ͼv">=</span><span class="ͼz">"paperSound"</span><span> </span><span class="ͼ12">preload</span><span class="ͼv">=</span><span class="ͼz">"auto"</span><span class="ͼ13">&gt;</span><br><span>    </span><span class="ͼ13">&lt;source</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"./paper.mp3"</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"audio/mpeg"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;/audio&gt;</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
<p data-start="931" data-end="964">👉 <code data-start="934" data-end="947">./paper.mp3</code> = SAME REPO ROOT</p>
