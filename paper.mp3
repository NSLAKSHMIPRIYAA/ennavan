&gt;</span><br><span class="ͼ13">&lt;html&gt;</span><br><span class="ͼ13">&lt;head&gt;</span><br><span class="ͼ13">&lt;title&gt;</span><span>Open When Letters</span><span class="ͼ13">&lt;/title&gt;</span><br><br><span class="ͼ13">&lt;link</span><span> </span><span class="ͼ12">href</span><span class="ͼv">=</span><span class="ͼz">"https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;600</span><span>&amp;</span><span class="ͼz">display=swap"</span><span> </span><span class="ͼ12">rel</span><span class="ͼv">=</span><span class="ͼz">"stylesheet"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;style&gt;</span><br><br><span class="ͼ13">body</span><span>{</span><br><span>    margin:</span><span class="ͼy">0</span><span>;</span><br><span>    font-family:</span><span class="ͼz">'Segoe UI'</span><span>, </span><span class="ͼy">sans-serif</span><span>;</span><br><span>    background: </span><span class="ͼv">linear-gradient</span><span>(</span><span class="ͼy">135</span><span class="ͼv">deg</span><span>,#ffd6e8,#ffe8d6,#e8d6ff);</span><br><span>    text-align:</span><span class="ͼy">center</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* title */</span><br><span class="ͼ13">h1</span><span>{</span><br><span>    margin:</span><span class="ͼy">25</span><span class="ͼv">px</span><span> </span><span class="ͼy">0</span><span>;</span><br><span>    color:#d63384;</span><br><span>}</span><br><br><span class="ͼt">/* GRID */</span><br><span>.</span><span class="ͼ10">grid</span><span>{</span><br><span>    display:</span><span class="ͼy">grid</span><span>;</span><br><span>    grid-template-columns: </span><span class="ͼv">repeat</span><span>(</span><span class="ͼy">2</span><span>, </span><span class="ͼy">160</span><span class="ͼv">px</span><span>);</span><br><span>    gap:</span><span class="ͼy">25</span><span class="ͼv">px</span><span>;</span><br><span>    justify-content:</span><span class="ͼy">center</span><span>;</span><br><span>    padding:</span><span class="ͼy">20</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* ✉️ MODERN ENVELOPE (UPDATED COLORS ONLY) */</span><br><span>.</span><span class="ͼ10">envelope-card</span><span>{</span><br><span>    width:</span><span class="ͼy">160</span><span class="ͼv">px</span><span>;</span><br><span>    height:</span><span class="ͼy">120</span><span class="ͼv">px</span><span>;</span><br><span>    background:#ffe3ec;   </span><span class="ͼt">/* changed from white → soft pink */</span><br><span>    border-radius:</span><span class="ͼy">12</span><span class="ͼv">px</span><span>;</span><br><span>    position:</span><span class="ͼy">relative</span><span>;</span><br><span>    cursor:</span><span class="ͼy">pointer</span><span>;</span><br><span>    box-shadow:</span><span class="ͼy">0</span><span> </span><span class="ͼy">6</span><span class="ͼv">px</span><span> </span><span class="ͼy">18</span><span class="ͼv">px</span><span> </span><span class="ͼv">rgba</span><span>(</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0.12</span><span>);</span><br><span>    transition:</span><span class="ͼy">0.3</span><span class="ͼv">s</span><span>;</span><br><span>    overflow:</span><span class="ͼy">hidden</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* envelope lines */</span><br><span>.</span><span class="ͼ10">envelope-card</span><span>::</span><span class="ͼ10">before</span><span>,</span><br><span>.</span><span class="ͼ10">envelope-card</span><span>::</span><span class="ͼ10">after</span><span>{</span><br><span>    content:</span><span class="ͼz">""</span><span>;</span><br><span>    position:</span><span class="ͼy">absolute</span><span>;</span><br><span>    width:</span><span class="ͼy">100</span><span class="ͼv">%</span><span>;</span><br><span>    height:</span><span class="ͼy">2</span><span class="ͼv">px</span><span>;</span><br><span>   