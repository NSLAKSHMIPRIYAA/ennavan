span> </span><span class="ͼ12">id</span><span class="ͼv">=</span><span class="ͼz">"paperSound"</span><span> </span><span class="ͼ12">preload</span><span class="ͼv">=</span><span class="ͼz">"auto"</span><span class="ͼ13">&gt;</span><br><span>    </span><span class="ͼ13">&lt;source</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"..."</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"audio/ogg"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;/audio&gt;</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
<hr data-start="552" data-end="555">
<h2 data-section-id="tcqsit" data-start="557" data-end="596">✅ ADD THIS SCRIPT ON TOP (important)</h2>
<p data-start="598" data-end="647">Put this inside <code data-start="614" data-end="624">&lt;script&gt;</code> before <code data-start="632" data-end="646">openLetter()</code>:</p>
<pre class="overflow-visible! px-0!" data-start="649" data-end="1353"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="relative h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="select-none sticky z-2 top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#e45ab3" fill="currentColor"></use></svg>JavaScript</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button type="button" class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class=""><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span class="ͼv">let</span><span> </span><span class="ͼ11">audioCtx</span><span>;</span><br><br><span class="ͼv">function</span><span> </span><span class="ͼ11">playPaperSound</span><span>() {</span><br><span>    </span><span class="ͼv">try</span><span> {</span><br><span>        </span><span class="ͼv">if</span><span> (</span><span class="ͼv">!</span><span class="ͼ11">audioCtx</span><span>) {</span><br><span>            </span><span class="ͼ11">audioCtx</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼv">new</span><span> (</span><span class="ͼ11">window</span><span class="ͼv">.</span><span>AudioContext </span><span class="ͼv">||</span><span> </span><span class="ͼ11">window</span><span class="ͼv">.</span><span>webkitAudioContext)();</span><br><span>        }</span><br><br><span>        </span><span class="ͼv">const</span><span> </span><span class="ͼ11">oscillator</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">audioCtx</span><span class="ͼv">.</span><span>createOscillator();</span><br><span>        </span><span class="ͼv">const</span><span> </span><span class="ͼ11">gainNode</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">audioCtx</span><span class="ͼv">.</span><span>createGain();</span><br><br><span>        </span><span class="ͼ11">oscillator</span><span class="ͼv">.</span><span>type </span><span class="ͼv">=</span><span> </span><span class="ͼz">"triangle"</span><span>;</span><br><span>        </span><span class="ͼ11">oscillator</span><span class="ͼv">.</span><span>frequency</span><span class="ͼv">.</span><span>value </span><span class="ͼv">=</span><span> </span><span class="ͼy">600</span><span>; </span><span class="ͼt">// soft paper click sound</span><br><br><span>        </span><span class="ͼ11">gainNode</span><span class="ͼv">.</span><span>gain</span><span class="ͼv">.</span><span>value </span><span class="ͼv">=</span><span> </span><span class="ͼy">0.05</span><span>; </span><span class="ͼt">// volume</span><br><br><span>        </span><span class="ͼ11">oscillator</span><span class="ͼv">.</span><span>connect(</span><span class="ͼ11">gainNode</span><span>);</span><br><span>        </span><span class="ͼ11">gainNode</span><span class="ͼv">.</span><span>connect(</span><span class="ͼ11">audioCtx</span><span class="ͼv">.</span><span>destination);</span><br><br><span>        </span><span class="ͼ11">oscillator</span><span class="ͼv">.</span><span>start();</span><br><br><span>        </span><span class="ͼ11">setTimeout</span><span>(() =&gt; {</span><br><span>            </span><span class="ͼ11">oscillator</span><span class="ͼv">.</span><span>stop();</span><br><span>        }, </span><span class="ͼy">120</span><span>);</span><br><br><span>    } </span><span class="ͼv">catch</span><span> (</span><span class="ͼ11">e</span><span>) {</span><br><span>        </span><span class="ͼ11">console</span><span class="ͼv">.</span><span>log(</span><span class="ͼz">"Audio error:"</span><span>, </span><span class="ͼ11">e</span><span>);</span><br><span>    }</span><br><span>}</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
<hr data-start="1355" data-end="1358">
<h2 data-section-id="1xdrk7h" data-start="1360" data-end="1400">🎧 NOW CALL IT IN YOUR CLICK FUNCTION</h2>
<p data-start="1402" data-end="1453">Inside <code data-start="1409" data-end="1423">openLetter()</code> replace your sound code with:</p>
