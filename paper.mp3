lor"></use></svg></button></span><span class="" data-state="closed"><button type="button" aria-label="Preview" aria-pressed="false" aria-disabled="false" class="relative z-1 flex size-9 items-center justify-center rounded-full motion-safe:transition-colors text-token-text-primary" data-code-block-preview-toggle-preview="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#6ef7a4" fill="currentColor"></use></svg></button></span></div><button type="button" class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div data-custom-highlighting-behavior="boundary" class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class=""><div class="relative [container-type:inline-size]"><div class="w-full overflow-x-hidden overflow-y-auto" style="max-height: 56.25cqw; transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span class="ͼ13">&lt;audio</span><span> </span><span class="ͼ12">id</span><span class="ͼv">=</span><span class="ͼz">"paperSound"</span><span> </span><span class="ͼ12">preload</span><span class="ͼv">=</span><span class="ͼz">"auto"</span><span class="ͼ13">&gt;</span><br><span>    </span><span class="ͼ13">&lt;source</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"paper.mp3"</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"audio/mpeg"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;/audio&gt;</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
<hr data-start="1136" data-end="1139">
<h2 data-section-id="1rd0kg0" data-start="1141" data-end="1193">🔓 STEP 3 — ADD Brave-friendly unlock (IMPORTANT)</h2>
<p data-start="1195" data-end="1234">Add this at the TOP of your <code data-start="1223" data-end="1233">&lt;script&gt;</code>:</p>
<pre class="overflow-visible! px-0!" data-start="1236" data-end="1587"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="relative h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="select-none sticky z-2 top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#e45ab3" fill="currentColor"></use></svg>JavaScript</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button type="button" class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class=""><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span class="ͼv">let</span><span> </span><span class="ͼ11">audioUnlocked</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼy">false</span><span>;</span><br><br><span class="ͼ11">document</span><span class="ͼv">.</span><span>addEventListener(</span><span class="ͼz">"click"</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼv">if</span><span> (</span><span class="ͼ11">audioUnlocked</span><span>) </span><span class="ͼv">return</span><span>;</span><br><br><span>    </span><span class="ͼv">const</span><span> </span><span class="ͼ11">sound</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">document</span><span class="ͼv">.</span><span>getElementById(</span><span class="ͼz">"paperSound"</span><span>);</span><br><br><span>    </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>play()</span><span class="ͼv">.</span><span>then(() =&gt; {</span><br><span>        </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>pause();</span><br><span>        </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>currentTime </span><span class="ͼv">=</span><span> </span><span class="ͼy">0</span><span>;</span><br><span>        </span><span class="ͼ11">audioUnlocked</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼy">true</span><span>;</span><br><span>        </span><span class="ͼ11">console</span><span class="ͼv">.</span><span>log(</span><span class="ͼz">"Audio unlocked"</span><span>);</span><br><span>    })</span><span class="ͼv">.</span><span>catch(() =&gt; {});</span><br><span>});</span></code></pre></div></div></div></div></div></div></div></div><div