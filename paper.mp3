&lt;html&gt;
&lt;head&gt;
&lt;title&gt;Open When Letters&lt;/title&gt;

&lt;link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;600&amp;display=swap" rel="stylesheet"&gt;

&lt;style&gt;

body{
    margin:0;
    font-family:'Segoe UI', sans-serif;
    background: linear-gradient(135deg,#ffd6e8,#ffe8d6,#e8d6ff);
    text-align:center;
}

/* title */
h1{
    margin:25px 0;
    color:#d63384;
}

/* GRID */
.grid{
    display:grid;
    grid-template-columns: repeat(2, 160px);
    gap:25px;
    justify-content:center;
    padding:20px;
}

/* ✉️ MODERN ENVELOPE (like your image) */
.envelope-card{
    width:160px;
    height:120px;
    background:#fff;
    border-radius:12px;
    position:relative;
    cursor:pointer;
    box-shadow:0 6px 18px rgba(0,0,0,0.12);
    transition:0.3s;
    overflow:hidden;
}

/* envelope lines */
.envelope-card::before,
.envelope-card::after{
    content:"";
    position:absolute;
    width:100%;
    height:2px;
    background:#e0e0e0;
    top:50%;
    transform:rotate(35deg);
}

.envelope-card::after{
    transform:rotate(-35deg);
}

/* top flap triangle */
.flap{
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:55%;
    background:#f4d03f;
    clip-path: polygon(0 0, 100% 0, 50% 100%);
}

/* heart badge */
.badge{
    position:absolute;
    top:8px;
    right:8px;
    background:#ff6b81;
    color:white;
    font-size:12px;
    padding:4px 6px;
    border-radius:50%;
}

/* label */
.tag{
    position:absolute;
    bottom:10px;
    width:100%;
    font-size:0.85rem;
    color:#333;
}

/* hover */
.envelope-card:hover{
    transform: translateY(-5px);
}

/* POPUP */
.overlay{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.5);
    display:none;
    justify-content:center;
    align-items:center;
}

/* opened card */
.open-envelope{
    width:340px;
    background:#fff;
    border-radius:10px;
    position:relative;
    padding:25px;
    animation: pop 0.4s ease;
}

/* paper */
.paper{
    font-family:'Dancing Script', cursive;
    font-size:1.4rem;
    color:#2c2c2c;
    background:#fafafa;
    padding:20px;
    border-radius:10px;
    animation: fadeIn 0.5s ease;
}

/* close */
.close{
    position:absolute;
    top:10px;
    right:15px;
    cursor:pointer;
    font-size:18px;
}

/* animations */
@keyframes pop{
    from{transform:scale(0.6); opacity:0;}
    to{transform:scale(1); opacity:1;}
}

@keyframes fadeIn{
    from{opacity:0; transform:translateY(10px);}
    to{opacity:1; transform:translateY(0);}
}

a{
    display:inline-block;
    margin:20px;
    color:#333;
    text-decoration:none;
    font-weight:bold;
}

/* heart burst */
.heart{
    position:fixed;
    font-size:16px;
    animation: floatUp 1.5s linear forwards;
}

@keyframes floatUp{
    0%{transform:translateY(0);opacity:1;}
    100%{transform:translateY(-120px);opacity:0;}
}

&lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;h1&gt;💌 Open When Letters&lt;/h1&gt;

&lt;div class="grid"&gt;

&lt;div class="envelope-card" onclick="openLetter('happy')"&gt;
    &lt;div class="flap"&gt;&lt;/div&gt;
    &lt;div class="badge"&gt;❤&lt;/div&gt;
    &lt;div class="tag"&gt;Happy&lt;/div&gt;
&lt;/div&gt;

&lt;div class="envelope-card" onclick="openLetter('sad')"&gt;
    &lt;div class="flap"&gt;&lt;/div&gt;
    &lt;div class="badge"&gt;❤&lt;/div&gt;
    &lt;div class="tag"&gt;Sad&lt;/div&gt;
&lt;/div&gt;

&lt;div class="envelope-card" onclick="openLetter('miss')"&gt;
    &lt;div class="flap"&gt;&lt;/div&gt;
    &lt;div class="badge"&gt;❤&lt;/div&gt;
    &lt;div class="tag"&gt;Miss me&lt;/div&gt;
&lt;/div&gt;

&lt;div class="envelope-card" onclick="openLetter('tired')"&gt;
    &lt;div class="flap"&gt;&lt;/div&gt;
    &lt;div class="badge"&gt;❤&lt;/div&gt;
    &lt;div class="tag"&gt;Tired&lt;/div&gt;
&lt;/div&gt;

&lt;/div&gt;

&lt;!-- POPUP --&gt;
&lt;div class="overlay" id="overlay" onclick="closeLetter(event)"&gt;
    &lt;div class="open-envelope"&gt;

        &lt;div class="close" onclick="closeLetter(event)"&gt;✖&lt;/div&gt;

        &lt;div class="paper" id="paperText"&gt;&lt;/div&gt;

    &lt;/div&gt;
&lt;/div&gt;

&lt;!-- safer audio --&gt;
&lt;audio id="paperSound" preload="auto"&gt;
&lt;source src="https://assets.mixkit.co/sfx/preview/mixkit-paper-slide-1531.mp3" type="audio/mpeg"&gt;
&lt;/audio&gt;

&lt;a href="index.html"&gt;⬅ Back&lt;/a&gt;

&lt;script&gt;

const messages = {
    happy: "I'm smiling because you're smiling ❤️",
    sad: "No matter what happens, I'm always here for you ❤️",
    miss: "Imagine me giving you the biggest hug right now ❤️",
    tired: "Rest okay? You mean everything to me ❤️"
};

function openLetter(type){

    document.getElementById("paperText").innerText = messages[type];
    document.getElementById("overlay").style.display = "flex";

    /* SOUND FIX */
    const sound = document.getElementById("paperSound");
    sound.currentTime = 0;
    sound.play().catch(()=&gt;{console.log("sound blocked");});

    /* HEART BURST */
    for(let i=0;i&lt;10;i++){
        const h=document.createElement("div");
        h.className="heart";
        h.innerHTML="❤️";
        h.style.left=Math.random()*100+"vw";
        h.style.top="60%";
        document.body.appendChild(h);

        setTimeout(()=&gt;h.remove(),1500);
    }
}

function closeLetter(e){
    if(e.target.id==="overlay" || e.target.className==="close"){
        document.getElementById("overlay").style.display="none";
    }
}

&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt; this is my code. the envelope is in yello and white . it doesnt suit my pink background. i want the envelops color to suit my pink bg. change that alone and nothing else and send me thw whole code</div></div><button type="button" aria-controls="_r_3d_" aria-expanded="false" class="A_HxFq_toggleControl select-none" data-testid="collapsible-user-message-toggle"><span class="A_HxFq_showMoreLabel">Show more</span><span class="A_HxFq_showLessLabel">Show less</span><div class="A_HxFq_toggleIconWrapper motion-safe:transition-transform motion-safe:duration-150"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" aria-hidden="true" class="A_HxFq_toggleIcon"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#ba3792" fill="currentColor"></use></svg></div></button></div></div></div></div></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-toke