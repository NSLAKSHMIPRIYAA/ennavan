ve"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span class="ͼ11">document</span><span class="ͼv">.</span><span>addEventListener(</span><span class="ͼz">"click"</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼv">const</span><span> </span><span class="ͼ11">sound</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">document</span><span class="ͼv">.</span><span>getElementById(</span><span class="ͼz">"paperSound"</span><span>);</span><br><span>    </span><span class="ͼv">if</span><span> (</span><span class="ͼv">!</span><span class="ͼ11">sound</span><span>) </span><span class="ͼv">return</span><span>;</span><br><br><span>    </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>play()</span><span class="ͼv">.</span><span>then(() =&gt; {</span><br><span>        </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>pause();</span><br><span>        </span><span class="ͼ11">sound</span><span class="ͼv">.</span><span>currentTime </span><span class="ͼv">=</span><span> </span><span class="ͼy">0</span><span>;</span><br><span>    })</span><span class="ͼv">.</span><span>catch(() =&gt; {});</span><br><span>}, { once: </span><span class="ͼy">true</span><span> });</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
