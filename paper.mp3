<p data-start="5843" data-end="5880"><span class="entity-underline hover:entity-accent group inline cursor-pointer align-baseline whitespace-nowrap" role="button" tabindex="0"><span class="inline-flex items-center overflow-hidden align-middle" aria-hidden="true" style="opacity: 1; width: 1.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="group-hover:entity-accent icon text-token-text-primary inline-block transition-transform duration-150 ease-out group-hover:translate-x-0.5"><use href="/cdn/assets/sprites-core-9a8a5f2a.svg#e04414" fill="currentColor"></use></svg></span><span class="group-hover:entity-accent whitespace-normal">letter slides out like real paper</span></span></p>
