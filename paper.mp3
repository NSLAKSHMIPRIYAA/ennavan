rue,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"619645130\":{\"name\":\"619645130\",\"rule_id\":\"disabled\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_impressions\":-1,\"max_days_visible\":-1,\"one_impression_per_day\":false},\"is_device_based\":false,\"passed\":false},\"3923090434\":{\"name\":\"3923090434\",\"rule_id\":\"3oWlxtnoHKmdKG6BLo9K8B:100.00:2-3oWlxrImfscJrgyGage6Pz\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"changelog_latest_date\":\"2026-05-04\",\"2026-05-04\":[\"Slack notifications: Get notified about new findings with the Codex Slack app. Go to the Scans page and select a scan you own to set up and customize alerts by severity, path, and keywords.\"]},\"is_device_based\":false,\"passed\":true},\"4232437627\":{\"name\":\"4232437627\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"asdk_app_697d413990c88191a2bf4799604f8f6c\":\"Turn on the ChatGPT App in [Salesforce](https://login.salesforce.com/lightning/setup/page/feature/sales-cloud-gpt/home?topic=SalesforceGo). View [documentation](https://help.salesforce.com/s/articleView?id=005237165\u0026type=1) for setup guidance.\",\"asdk_app_693ae33dd0f081918003ca256fe1126b\":\"Turn on the ChatGPT App in [Salesforce](https://login.salesforce.com/lightning/setup/page/feature/sales-cloud-gpt/home?topic=SalesforceGo). View [documentation](https://help.salesforce.com/s/articleView?id=005237165\u0026type=1) for setup guidance.\"},\"is_device_based\":false,\"passed\":false},\"4223845460\":{\"name\":\"4223845460\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"timing_unsend_window_sec\":7,\"web_timing_max_attempts\":10,\"timing_unsend_buffer_sec\":3,\"timing_cancel_send_timeout_sec\":10,\"web_timing_poll_interval_ms\":1500},\"is_device_based\":false,\"passed\":false},\"1638994742\":{\"name\":\"1638994742\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"web_disabled_file_previewer_types\":[]},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"1025202184\":{\"name\":\"1025202184\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\